{
  "name": "n8n-nodes-guidedmind",
  "version": "0.1.3",
  "description": "n8n community node for GuidedMind — RAG knowledge base, document ingestion, and short/long agent memory.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "guidedmind",
    "rag",
    "memory",
    "retrieval"
  ],
  "license": "MIT",
  "homepage": "https://guidedmind.ai",
  "author": {
    "name": "GuidedMind, Inc.",
    "email": "hello@guidedmind.ai"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guidedmind-ai/n8n-nodes-guidedmind.git"
  },
  "engines": {
    "node": ">=20.15"
  },
  "main": "index.js",
  "scripts": {
    "build": "npx rimraf dist && tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint 'nodes/**/*.ts' 'credentials/**/*.ts'",
    "lint:fix": "eslint 'nodes/**/*.ts' 'credentials/**/*.ts' --fix",
    "prepublishOnly": "npm run build && npm run lint",
    "release": "n8n-node release"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/GuidedMindRagApi.credentials.js",
      "dist/credentials/GuidedMindMemoryApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/GuidedMind/GuidedMind.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "^0.37.1",
    "@typescript-eslint/parser": "~8.32.0",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.3",
    "gulp": "^5.0.0",
    "n8n-workflow": "*",
    "prettier": "^3.5.3",
    "rimraf": "^5.0.5",
    "typescript": "^5.8.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
